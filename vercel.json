{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/creators",
      "destination": "/creators/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}